@model CartPageViewModel
@{
    ViewData["Title"] = "Sepet";
}

<div class="site-shell">
    <header class="topbar">
        <div class="topbar__inner section-container">
            <a class="topbar__brand" asp-controller="Home" asp-action="Index">FUWANS</a>
            <nav class="topbar__nav" aria-label="Ana menu">
                <a class="topbar__link" asp-controller="Products" asp-action="Index">Urunler</a>
                <a class="topbar__link" asp-controller="Home" asp-action="About">Hakkimizda</a>
                <a class="topbar__link" asp-controller="Home" asp-action="Index" asp-fragment="bulten">Iletisim</a>
            </nav>
            <div class="topbar__actions" aria-label="Hizli islemler">
                <button class="icon-button" type="button" aria-label="Hesabim">
                    <span class="material-symbols-outlined">person</span>
                </button>
                <button class="icon-button" type="button" aria-label="Favoriler">
                    <span class="material-symbols-outlined">favorite</span>
                </button>
                <a class="icon-button icon-button--cart" asp-controller="Cart" asp-action="Index" aria-label="Sepet">
                    <span class="material-symbols-outlined">shopping_bag</span>
                    @if (Model.SelectedItemCount > 0)
                    {
                        <span class="cart-badge">@Model.SelectedItemCount</span>
                    }
                </a>
            </div>
        </div>
    </header>

    <main class="section-container cart-page">
        <header class="cart-page__header">
            <h1>Secili Koleksiyonunuz</h1>
            <p>@Model.SelectedItemCount urun satin alim icin secildi</p>
        </header>

        <div class="cart-page__grid">
            <section class="cart-list">
                @if (Model.Items.Count == 0)
                {
                    <div class="cart-empty">
                        <h2>Sepetiniz su an bos</h2>
                        <p>Koleksiyonunuz icin urun secmeye devam edebilirsiniz.</p>
                        <a class="button button--solid" asp-controller="Products" asp-action="Index">Urunleri Kesfet</a>
                    </div>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <article class="cart-item">
                            <a class="cart-item__image" asp-controller="Products" asp-action="Details" asp-route-slug="@item.ProductSlug">
                                <img src="@item.ProductImageUrl" alt="@item.ProductName" />
                            </a>
                            <div class="cart-item__content">
                                <div class="cart-item__top">
                                    <div>
                                        <h3>@item.ProductName</h3>
                                        <p>@item.DetailText</p>
                                    </div>
                                    <span>@item.PriceText</span>
                                </div>
                                <div class="cart-item__bottom">
                                    <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="cart-qty">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" name="delta" value="-1">
                                            <span class="material-symbols-outlined">remove</span>
                                        </button>
                                        <span>@item.Quantity.ToString("00")</span>
                                        <button type="submit" name="delta" value="1">
                                            <span class="material-symbols-outlined">add</span>
                                        </button>
                                    </form>
                                    <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button class="cart-remove" type="submit">
                                            <span class="material-symbols-outlined">close</span>
                                            Urunu Kaldir
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                }
            </section>

            <aside class="cart-summary">
                <div class="cart-summary__card">
                    <h2>Ozet</h2>
                    <div class="cart-summary__rows">
                        <div><span>Ara Toplam</span><span>@Model.SubtotalText</span></div>
                        <div><span>Tahmini Kargo</span><span>Ucretsiz</span></div>
                        <div><span>Vergi</span><span>Sonraki adimda hesaplanir</span></div>
                    </div>
                    <div class="cart-summary__total">
                        <span>Toplam</span>
                        <strong>@Model.TotalText</strong>
                    </div>
                    <form asp-controller="Cart" asp-action="BeginCheckout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="button button--solid cart-summary__button" type="submit">Odeme Adimina Gec</button>
                    </form>
                    @if (TempData["CheckoutMessage"] is string message)
                    {
                        <p class="cart-summary__message">@message</p>
                    }
                    <p class="cart-summary__note">Guvenli odeme akisi ve imzali teslimat her sipariste dahildir.</p>
                </div>
                <a class="cart-summary__continue" asp-controller="Products" asp-action="Index">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Alisverise Devam Et
                </a>
            </aside>
        </div>
    </main>
</div>
