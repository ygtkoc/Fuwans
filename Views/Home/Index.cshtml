@model HomePageViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="site-shell">
    <header class="topbar">
        <div class="topbar__inner section-container">
            <nav class="topbar__nav" aria-label="Primary">
                <a class="topbar__link topbar__link--active" href="#featured-products">Shop</a>
                <a class="topbar__link" href="#brand-story">About</a>
                <a class="topbar__link" href="#newsletter">Contact</a>
            </nav>
            <a class="topbar__brand" asp-controller="Home" asp-action="Index">FUWANS</a>
            <div class="topbar__actions" aria-label="Quick actions">
                <button class="icon-button" type="button" aria-label="Account">
                    <span class="material-symbols-outlined">person</span>
                </button>
                <button class="icon-button" type="button" aria-label="Wishlist">
                    <span class="material-symbols-outlined">favorite</span>
                </button>
                <button class="icon-button" type="button" aria-label="Shopping bag">
                    <span class="material-symbols-outlined">shopping_bag</span>
                </button>
            </div>
        </div>
    </header>

    <section class="hero">
        <div class="hero__media">
            <img src="@Model.Hero.ImageUrl" alt="@Model.Hero.Title" />
            <div class="hero__overlay"></div>
        </div>
        <div class="hero__content section-container">
            <span class="eyebrow">@Model.Hero.Eyebrow</span>
            <h1>@Model.Hero.Title</h1>
            <div class="hero__actions">
                <a class="button button--solid" href="#featured-products">@Model.Hero.PrimaryActionText</a>
                <a class="button button--ghost" href="#category-highlights">@Model.Hero.SecondaryActionText</a>
            </div>
        </div>
    </section>

    <section class="feature-strip">
        <div class="section-container feature-strip__items">
            @foreach (var feature in Model.Features)
            {
                <div class="feature-strip__item">
                    <span class="material-symbols-outlined">@feature.IconName</span>
                    <span>@feature.Title</span>
                </div>
            }
        </div>
    </section>

    <section class="section-container section-spacing" id="featured-products">
        <div class="section-heading">
            <div>
                <h2>The Essentials</h2>
                <p>@Model.FeaturedProductsDescription</p>
            </div>
            <a class="section-link" href="#category-highlights">View All</a>
        </div>

        @if (Model.FeaturedProducts.Count > 0)
        {
            var featuredProduct = Model.FeaturedProducts[0];
            var secondaryProducts = Model.FeaturedProducts.Skip(1).ToList();

            <div class="product-grid">
                <article class="product-card product-card--featured">
                    <div class="product-card__image product-card__image--tall">
                        <img src="@featuredProduct.PrimaryImageUrl" alt="@featuredProduct.Name" />
                    </div>
                    <div class="product-card__header">
                        <h3>@featuredProduct.Name</h3>
                        <span>@featuredProduct.PriceText</span>
                    </div>
                    <p class="product-card__meta">@featuredProduct.ShortDescription</p>
                </article>

                <div class="product-grid__stack">
                    @foreach (var product in secondaryProducts)
                    {
                        <article class="product-card">
                            <div class="product-card__image product-card__image--square">
                                <img src="@product.PrimaryImageUrl" alt="@product.Name" />
                            </div>
                            <div class="product-card__header">
                                <h3>@product.Name</h3>
                                <span>@product.PriceText</span>
                            </div>
                            <p class="product-card__meta">@product.ShortDescription</p>
                        </article>
                    }
                </div>
            </div>
        }
    </section>

    <section class="collection-band section-spacing" id="category-highlights">
        <div class="section-container category-grid">
            @foreach (var category in Model.HighlightCategories)
            {
                <article class="category-card">
                    <img src="@category.HighlightImageUrl" alt="@category.Name" />
                    <div class="category-card__overlay">
                        <h3>@category.Name</h3>
                        <a href="#featured-products">
                            @category.CallToActionText
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="section-container section-spacing story-grid" id="brand-story">
        <div class="story-grid__media">
            <div class="story-grid__frame">
                <img src="@Model.BrandStory.ImageUrl" alt="@Model.BrandStory.Title" />
            </div>
        </div>
        <div class="story-grid__content">
            <span class="eyebrow eyebrow--dark">@Model.BrandStory.Eyebrow</span>
            <h2>@Model.BrandStory.Title</h2>
            <div class="story-grid__text">
                @foreach (var paragraph in Model.BrandStory.Paragraphs)
                {
                    <p>@paragraph</p>
                }
            </div>
            <a class="section-link" href="#newsletter">@Model.BrandStory.ActionText</a>
        </div>
    </section>

    <section class="newsletter section-spacing" id="newsletter">
        <div class="newsletter__inner section-container section-container--narrow">
            <h2>Join The Inner Circle</h2>
            <p>@Model.NewsletterDescription</p>

            @if (TempData["SubscriptionMessage"] is string message)
            {
                <div class="newsletter__message">@message</div>
            }

            <form asp-action="Subscribe" asp-controller="Home" method="post" class="newsletter__form">
                @Html.AntiForgeryToken()
                <div class="newsletter__field">
                    <label asp-for="SubscriptionEmail">Email Address</label>
                    <input asp-for="SubscriptionEmail" type="email" placeholder="YOUR@EMAIL.COM" />
                </div>
                <button class="button button--solid" type="submit">Subscribe</button>
            </form>
        </div>
    </section>

    <footer class="footer">
        <div class="section-container footer__grid">
            <div>
                <div class="footer__brand">FUWANS</div>
                <p class="footer__summary">@Model.FooterSummary</p>
            </div>
            <div class="footer__links">
                <div>
                    <span>Discover</span>
                    <a href="#featured-products">Shop</a>
                    <a href="#category-highlights">Collections</a>
                    <a href="#brand-story">Bespoke</a>
                </div>
                <div>
                    <span>Company</span>
                    <a href="#brand-story">About</a>
                    <a href="#newsletter">Sustainability</a>
                    <a asp-controller="Home" asp-action="Privacy">Legal</a>
                </div>
            </div>
            <div class="footer__meta">
                <div class="footer__icons">
                    <a href="#" aria-label="Global">
                        <span class="material-symbols-outlined">language</span>
                    </a>
                    <a href="#" aria-label="Share">
                        <span class="material-symbols-outlined">share</span>
                    </a>
                </div>
                <div>© 2026 FUWANS. DEFINING MODERN HERITAGE.</div>
            </div>
        </div>
    </footer>
</div>
