@model ProductDetailPageViewModel
@{
    ViewData["Title"] = Model.Name;
    var largeImage = Model.GalleryImages.FirstOrDefault();
    var supportingImages = Model.GalleryImages.Skip(1).ToList();
}

<div class="site-shell">
    <header class="topbar">
        <div class="topbar__inner section-container">
            <nav class="topbar__nav" aria-label="Ana menu">
                <a class="topbar__link topbar__link--active" asp-controller="Products" asp-action="Index">Urunler</a>
                <a class="topbar__link" asp-controller="Home" asp-action="About">Hakkimizda</a>
                <a class="topbar__link" asp-controller="Home" asp-action="Index" asp-fragment="bulten">Iletisim</a>
            </nav>
            <a class="topbar__brand" asp-controller="Home" asp-action="Index">FUWANS</a>
            <div class="topbar__actions" aria-label="Hizli islemler">
                <button class="icon-button" type="button" aria-label="Hesabim">
                    <span class="material-symbols-outlined">person</span>
                </button>
                <button class="icon-button" type="button" aria-label="Favoriler">
                    <span class="material-symbols-outlined">favorite</span>
                </button>
                <button class="icon-button" type="button" aria-label="Sepet">
                    <span class="material-symbols-outlined">shopping_bag</span>
                </button>
            </div>
        </div>
    </header>

    <main class="section-container detail-page">
        <div class="detail-page__grid">
            <section class="detail-gallery">
                @if (largeImage is not null)
                {
                    <div class="detail-gallery__hero">
                        <img src="@largeImage.ImageUrl" alt="@largeImage.AltText" />
                    </div>
                }

                @foreach (var image in supportingImages)
                {
                    <div class="detail-gallery__support">
                        <img src="@image.ImageUrl" alt="@image.AltText" />
                    </div>
                }
            </section>

            <section class="detail-content">
                <div>
                    <span class="eyebrow eyebrow--dark">@Model.CollectionLabel</span>
                    <h1 class="detail-content__title">@Model.Name</h1>
                    <p class="detail-content__price">@Model.PriceText</p>
                </div>

                <p class="detail-content__description">@Model.Description</p>

                <div class="detail-selector">
                    <span class="detail-selector__label">Renk - @Model.SelectedColorName</span>
                    <div class="detail-selector__colors">
                        @foreach (var color in Model.Colors)
                        {
                            var selectedClass = color.IsSelected ? "detail-color detail-color--selected" : "detail-color";
                            <span class="@selectedClass" title="@color.Name" style="background-color:@color.HexCode"></span>
                        }
                    </div>
                </div>

                <div class="detail-selector">
                    <div class="detail-selector__header">
                        <span class="detail-selector__label">Beden</span>
                        <button class="detail-inline-button" type="button">Beden Rehberi</button>
                    </div>
                    <div class="detail-sizes">
                        @foreach (var size in Model.Sizes)
                        {
                            var selectedClass = size.IsSelected ? "detail-size detail-size--selected" : "detail-size";
                            <span class="@selectedClass">@size.Label</span>
                        }
                    </div>
                    <p class="detail-selector__help">@Model.SizeGuideText</p>
                </div>

                <div class="detail-actions">
                    <button class="button button--solid detail-actions__primary" type="button">Sepete Ekle</button>
                    <button class="detail-actions__secondary" type="button">
                        <span class="material-symbols-outlined">favorite</span>
                        Favorilere Ekle
                    </button>
                </div>

                <div class="detail-accordion">
                    <details open>
                        <summary>Detaylar</summary>
                        <p>@Model.DetailsText</p>
                    </details>
                    <details>
                        <summary>Malzemeler</summary>
                        <p>@Model.MaterialsText</p>
                    </details>
                    <details>
                        <summary>Teslimat ve Iade</summary>
                        <p>@Model.ShippingReturnsText</p>
                    </details>
                </div>
            </section>
        </div>

        <section class="detail-related">
            <h2>Hosunuza Gidebilir</h2>
            <div class="detail-related__grid">
                @foreach (var product in Model.RelatedProducts)
                {
                    <article class="detail-related__card">
                        <a asp-controller="Products" asp-action="Details" asp-route-slug="@product.Slug">
                            <div class="detail-related__image">
                                <img src="@product.ImageUrl" alt="@product.Name" />
                            </div>
                            <p>@product.Name</p>
                            <span>@product.PriceText</span>
                        </a>
                    </article>
                }
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="section-container footer__grid footer__grid--catalog">
            <div>
                <div class="footer__brand">FUWANS</div>
                <p class="footer__summary">(c) 2026 FUWANS. MODERN MIRASI YENIDEN TANIMLIYORUZ.</p>
            </div>
            <div class="footer__links">
                <div>
                    <a href="#">Surdurulebilirlik</a>
                    <a asp-controller="Home" asp-action="Privacy">Yasal</a>
                </div>
                <div>
                    <a href="#">Teslimat</a>
                    <a asp-controller="Home" asp-action="Index" asp-fragment="bulten">Bulten</a>
                </div>
            </div>
            <div class="footer__social">
                <span>Kayit listemize katil</span>
                <div class="footer__newsletter">
                    <input type="email" placeholder="E-posta adresiniz" />
                    <button type="button" aria-label="Gonder">
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </div>
            </div>
        </div>
    </footer>
</div>
