@model CheckoutReviewPageViewModel
@{
    ViewData["Title"] = "Siparis Onayi";
}

<div class="site-shell">
    <header class="topbar">
        <div class="topbar__inner section-container">
            <a class="topbar__brand" asp-controller="Home" asp-action="Index">FUWANS</a>
            <div class="topbar__nav" aria-hidden="true">
                <span class="topbar__link topbar__link--active">Checkout</span>
            </div>
            <div class="topbar__actions">
                <a class="section-link" asp-controller="Products" asp-action="Index">Magazaya Don</a>
            </div>
        </div>
    </header>

    <main class="section-container checkout-page">
        <div class="checkout-layout">
            <section class="checkout-flow">
                <nav class="checkout-steps" aria-label="Checkout adimlari">
                    <span>01 Kargo</span>
                    <span>02 Odeme</span>
                    <span class="is-active">03 Onay</span>
                </nav>

                <section class="checkout-review">
                    <header>
                        <h1 class="checkout-review__title">Siparis Onayi</h1>
                        <p class="checkout-review__text">Bu ekran, teslimat ve odeme detaylarinizin tasarim icinde nasil gorunecegini gosterir.</p>
                    </header>

                    <div class="checkout-review__grid">
                        <article class="checkout-review__block">
                            <strong>Teslimat Bilgileri</strong>
                            <span>@Model.ShippingPreview.FullName</span>
                            <span>@Model.ShippingPreview.EmailAddress</span>
                            <span>@Model.ShippingPreview.StreetAddress</span>
                            <span>@Model.ShippingPreview.CityPostalCode</span>
                            <span>@Model.ShippingPreview.DeliveryTitle</span>
                            <span>@Model.ShippingPreview.DeliveryDescription</span>
                        </article>

                        <article class="checkout-review__block">
                            <strong>Odeme Bilgileri</strong>
                            <span>@Model.PaymentPreview.CardholderName</span>
                            <span>@Model.PaymentPreview.MaskedCardNumber</span>
                            <span>SKT: @Model.PaymentPreview.ExpirationText</span>
                            <span>@Model.PaymentPreview.InstallmentText</span>
                        </article>
                    </div>

                    <div class="checkout-panels">
                        <section class="checkout-panel">
                            <div class="checkout-panel__header">
                                <h2>Koleksiyon Ozetiniz</h2>
                                <a asp-controller="Cart" asp-action="Index">Sepeti Ac</a>
                            </div>
                            <div class="checkout-panel__body">
                                <strong>@Model.Summary.Items.Count urun secildi</strong>
                                <p>Bu asamada siparisi tamamlamiyoruz; sadece tasarimin review akisini goruyorsunuz.</p>
                            </div>
                        </section>
                    </div>

                    <div class="checkout-actions">
                        <a class="checkout-link" asp-action="Payment">
                            <span class="material-symbols-outlined">arrow_back</span>
                            Odemeye Don
                        </a>
                        <a class="button button--solid" asp-controller="Home" asp-action="Index">Ana Sayfaya Don</a>
                    </div>
                </section>
            </section>

            <aside class="checkout-summary">
                <partial name="_CheckoutSummary" model="Model.Summary" />
            </aside>
        </div>
    </main>

    <partial name="_CheckoutFooter" />
</div>
