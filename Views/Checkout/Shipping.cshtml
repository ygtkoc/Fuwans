@model CheckoutShippingPageViewModel
@{
    ViewData["Title"] = "Kargo Bilgileri";
}

<div class="site-shell">
    <header class="topbar">
        <div class="topbar__inner section-container">
            <a class="topbar__brand" asp-controller="Home" asp-action="Index">FUWANS</a>
            <div class="topbar__nav" aria-hidden="true">
                <span class="topbar__link topbar__link--active">Checkout</span>
            </div>
            <div class="topbar__actions">
                <a class="section-link" asp-controller="Products" asp-action="Index">Magazaya Don</a>
            </div>
        </div>
    </header>

    <main class="section-container checkout-page">
        <div class="checkout-layout">
            <section class="checkout-flow">
                <nav class="checkout-steps" aria-label="Checkout adimlari">
                    <span class="is-active">01 Kargo</span>
                    <span>02 Odeme</span>
                    <span>03 Onay</span>
                </nav>

                <section class="checkout-section">
                    <header>
                        <h1>Kargo Bilgileri</h1>
                        <p>Siparisinizi kusursuz bir teslimat deneyimiyle tamamlamak icin bilgilerinizi girin.</p>
                    </header>
                </section>

                <form asp-action="Shipping" method="post" class="checkout-form">
                    @Html.AntiForgeryToken()
                    <div class="checkout-form__grid">
                        <div class="checkout-field checkout-field--full">
                            <label asp-for="EmailAddress">E-Posta Adresi</label>
                            <input asp-for="EmailAddress" placeholder="alexander@heritage.com" />
                        </div>
                        <div class="checkout-field">
                            <label asp-for="FirstName">Ad</label>
                            <input asp-for="FirstName" placeholder="Alexander" />
                        </div>
                        <div class="checkout-field">
                            <label asp-for="LastName">Soyad</label>
                            <input asp-for="LastName" placeholder="Vance" />
                        </div>
                        <div class="checkout-field checkout-field--full">
                            <label asp-for="StreetAddress">Adres</label>
                            <input asp-for="StreetAddress" placeholder="Heritage Bulvari No:1242, Kat 4" />
                        </div>
                        <div class="checkout-field">
                            <label asp-for="City">Sehir</label>
                            <input asp-for="City" placeholder="Istanbul" />
                        </div>
                        <div class="checkout-field">
                            <label asp-for="PostalCode">Posta Kodu</label>
                            <input asp-for="PostalCode" placeholder="34000" />
                        </div>
                    </div>

                    <section class="checkout-delivery">
                        <h2>Teslimat Yontemi</h2>
                        @foreach (var option in Model.DeliveryOptions)
                        {
                            <label class="checkout-delivery__option @(option.IsSelected ? "checkout-delivery__option--selected" : string.Empty)">
                                <div class="checkout-delivery__meta">
                                    <div>
                                        <input type="radio" name="DeliveryMethod" value="@option.Code" checked="@option.IsSelected" />
                                        <strong>@option.Title</strong>
                                    </div>
                                    <span>@option.Description</span>
                                </div>
                                <strong class="checkout-delivery__price">@option.PriceText</strong>
                            </label>
                        }
                    </section>

                    <div class="checkout-actions">
                        <button class="button button--solid" type="submit">Odemeye Gec</button>
                    </div>
                </form>
            </section>

            <aside class="checkout-summary">
                <partial name="_CheckoutSummary" model="Model.Summary" />
            </aside>
        </div>
    </main>

    <partial name="_CheckoutFooter" />
</div>
