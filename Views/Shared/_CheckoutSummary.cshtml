@model CheckoutSummaryViewModel

<div class="checkout-summary__card">
    <header class="checkout-summary__header">
        <h2>Siparis Ozeti</h2>
    </header>

    <div class="checkout-summary__items">
        @foreach (var item in Model.Items)
        {
            <article class="checkout-summary__item">
                <a class="checkout-summary__item-image" asp-controller="Products" asp-action="Details" asp-route-slug="@item.ProductSlug">
                    <img src="@item.ProductImageUrl" alt="@item.ProductName" />
                </a>
                <div class="checkout-summary__item-body">
                    <div>
                        <h3>@item.ProductName</h3>
                        <p>@item.DetailText<br />Adet: @item.Quantity.ToString("00")</p>
                    </div>
                    <strong>@item.PriceText</strong>
                </div>
            </article>
        }
    </div>

    <div class="checkout-summary__promo">
        <input type="text" value="FUWANS10" readonly />
        <button type="button">Uygula</button>
    </div>

    <div class="checkout-summary__rows">
        <div><span>Ara Toplam</span><strong>@Model.SubtotalText</strong></div>
        <div><span>Kargo</span><strong>@Model.ShippingText</strong></div>
        <div><span>Tahmini Vergi</span><strong>@Model.TaxText</strong></div>
    </div>

    <div class="checkout-summary__total">
        <span>Toplam</span>
        <strong>@Model.TotalText</strong>
    </div>

    <div class="checkout-summary__trust">
        <div>
            <span class="material-symbols-outlined">lock</span>
            <div class="checkout-summary__meta">
                <strong>Guvenli Akis</strong>
                <span>256-bit sifreleme</span>
            </div>
        </div>
        <div>
            <span class="material-symbols-outlined">verified</span>
            <div class="checkout-summary__meta">
                <strong>FUWANS Sozu</strong>
                <span>Omur boyu garanti</span>
            </div>
        </div>
    </div>
</div>
